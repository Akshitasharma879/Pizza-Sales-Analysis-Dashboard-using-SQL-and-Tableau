                    <run fontalignment='1' fontcolor='#72b966' fontname='Segoe UI Semibold'>evening, from 4:00 P.M to 7:00</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#72b966' fontname='Segoe UI Semibold'> P.M</run>
                    <run fontalignment='1' fontname='Segoe UI Semibold'>Æ </run>
                    <run fontalignment='1'>Æ&#10;&#10;</run>
                    <run fontalignment='1' fontcolor='#75a1c7' fontname='Arial Black' underline='true'>WEEKS</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#e15759' fontname='Segoe UI Semibold'>Significant Variations in</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#e15759' fontname='Segoe UI Semibold'> Weekly Orders,</run>
                    <run fontalignment='1' fontname='Segoe UI Semibold'>Æ </run>
                    <run fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Semibold'>With highest</run>
                    <run fontalignment='1'>Æ&#10;</run>
                    <run fontalignment='1' fontcolor='#ffffff' fontname='Segoe UI Semibold'> peak during the</run>
